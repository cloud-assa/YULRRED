# SpacetimeDB — the ONLY database layer (no PostgreSQL/Prisma)
SPACETIMEDB_URL=https://maincloud.spacetimedb.com
SPACETIMEDB_DB=cloud-assa/securedeal
SPACETIMEDB_TOKEN=your_spacetimedb_token_here

# JWT (min 32 chars, change in production!)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRY=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (use Mailtrap for dev, or SendGrid/SES for prod)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=noreply@securedeal.com

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ESCROW_FEE_PERCENT=5
